{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @19er/db db:generate && pnpm turbo build --filter=@19er/api... --force",
  "outputDirectory": "public",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "apps/api/dist/**,packages/**/dist/**"
    }
  }
}
