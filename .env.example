# Database
DATABASE_URL="postgresql://19er:19er_dev_password@localhost:5433/19ergmbh?schema=public"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# API
API_PORT=3002
API_URL="http://localhost:3002"
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# Frontend (Vite) — /api uses dev proxy; set full URL for production builds
VITE_API_URL="/api"

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@19ergmbh.de

# WhatsApp (Metaphilia API)
WHATSAPP_API_KEY=
WHATSAPP_SENDER=
WHATSAPP_API_BASE=https://metaphilia.com

# Notification queue
NOTIFICATION_DELAY_MS=15000
NOTIFICATION_CRON=*/30 * * * *
NOTIFICATION_CRON_ENABLED=true
