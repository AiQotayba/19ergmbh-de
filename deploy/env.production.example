# Copy to repo root as .env on the server (never commit real values).
# In CI/CD, store the full file contents in the GitHub secret API_ENV.

NODE_ENV=production

# Database — mysql on production host
DATABASE_URL="mysql://USER:PASS@127.0.0.1:3306/DATABASE"
DATABASE_PROVIDER=mysql

# JWT — use strong random secrets (min 32 chars)
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# API
API_PORT=3003
API_URL="https://api.19ergmbh-de.com"
CORS_ORIGIN="https://19ergmbh-de.com,https://admin.19ergmbh-de.com"

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@19ergmbh.de

# WhatsApp (Metaphilia)
WHATSAPP_API_KEY=
WHATSAPP_SENDER=
WHATSAPP_API_BASE=https://metaphilia.com

# Notification queue
NOTIFICATION_DELAY_MS=15000
NOTIFICATION_CRON=*/30 * * * *
NOTIFICATION_CRON_ENABLED=true

# Vercel cron (optional — only when API runs on Vercel)
# CRON_SECRET=
